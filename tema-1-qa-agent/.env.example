# Copy this file to .env and fill in your values

# --- Provider activ (Alege unul dintre: ollama | gemini | openrouter | anthropic ---
LLM_PROVIDER=ollama

# --- # Ollama runs locally, no API key needed ---
OLLAMA_MODEL=llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434

# --- Google Gemini ---
# Obtine cheia de la: https://aistudio.google.com/apikey
GEMINI_API_KEY=AI...

# --- OpenRouter (acces la modele multiple: Claude, Gemini, Llama, etc.) ---
# Obtine cheia de la: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=openai/gpt-oss-120b:free

# --- Anthropic Claude ---
# Obtine cheia de la: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
